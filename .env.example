# Auto Content Production · environment overrides
#
# Copy this file to `.env` (same directory as shared_config.json) and
# fill in real values. shared_config.json references these via ${VAR}
# placeholders, so the JSON itself can be safely committed / shared.
#
# Required for real LLM calls (writing + platform_scorer). If empty, the
# affected modules fall back to mock mode where they support it.
DEEPSEEK_API_KEY=
QWEN_API_KEY=
